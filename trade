--[[
    Kick A Lucky Block - Trade Automation System
    
    GAME MECHANICS (DISCOVERED):
    - Trade sending: Network:InvokeServer("trade_r", userId)
    - Trade accepting: Network:FireServer("trade_start", userId)
    - Add item to trade: FireServer("AddItem", itemGUID) via rev_trade_i remote
    - Remove item from trade: FireServer("RemoveItem", itemGUID) via rev_trade_i remote
    - Confirm trade: FireServer("Confirm") via rev_trade_i remote
    - Inventory items: Tools in Backpack/Character with GUID attributes
    - Mutations: Tagged on tools using CollectionService
    - Rarities: Defined in EntitiesData for each Brainrot
    
    REMOTE LOCATION:
    ReplicatedStorage > Shared > Packages > Network > rev_trade_i
    
    USAGE:
    - Place this script as a LocalScript in StarterPlayer > StarterPlayerScripts
    - Requires access to ReplicatedStorage.Shared.Packages.Network
]]--

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local CollectionService = game:GetService("CollectionService")

local LocalPlayer = Players.LocalPlayer
local Backpack = LocalPlayer.Backpack
local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()

-- Load game modules
local Network = require(ReplicatedStorage.Shared.Packages.Network)
local EntitiesData = require(ReplicatedStorage.Shared.Data.EntitiesData)
local MutationData = require(ReplicatedStorage.Shared.Data.MutationData)

-- ============================================================================
-- CONFIGURATION
-- ============================================================================

local CONFIG = {
    -- Allowed rarities for trading
    AllowedRarities = {
        ["Celestial"] = true,
        ["Eternal"] = true,
    },
    
    -- Time to wait between adding items (prevents spam)
    AddItemDelay = 0.1,
    
    -- Time to wait before confirming trade
    ConfirmDelay = 0.5,
    
    -- Enable debug output
    DebugMode = true,
}

-- ============================================================================
-- UTILITY FUNCTIONS
-- ============================================================================

local function Log(message, level)
    level = level or "INFO"
    if CONFIG.DebugMode then
        print(string.format("[TradeAutomation | %s] %s", level, message))
    end
end

local function GetRarityValue(rarityName)
    -- Priority order: Celestial > Eternal
    local rarityMap = {
        Eternal = 2,
        Celestial = 3,
    }
    return rarityMap[rarityName] or 0
end

local function GetBrainrotRarity(toolName)
    -- Get rarity from EntitiesData
    if EntitiesData and EntitiesData.Brainrots then
        local brainrotData = EntitiesData.Brainrots[toolName]
        if brainrotData then
            return brainrotData.Rarity
        end
    end
    return nil
end

local function GetItemMutations(tool)
    -- Get mutations from CollectionService tags
    local mutations = {}
    local tags = CollectionService:GetTags(tool)
    
    for _, tag in ipairs(tags) do
        if MutationData.ValidMutations and table.find(MutationData.ValidMutations, tag) then
            table.insert(mutations, tag)
        end
    end
    
    return mutations
end

