local PublicAPI = {}

function PublicAPI.ExecuteTrade(userId)
    if not userId or userId == 0 then
        Log("Invalid userId", "ERROR")
        return false
    end
    
    return AutoTradeWorkflow.ExecuteFullTrade(userId)
end

function PublicAPI.ShowInventory()
    return InventoryScanner.PrintInventory()
end

function PublicAPI.ManualAddItem(toolNameOrGUID)
    -- Can accept either tool name or GUID
    local items = InventoryScanner.GetAllBrainrots()
    
    for _, tool in ipairs(items) do
        local guid = GetItemGUID(tool)
        -- Try matching by name or GUID
        if tool.Name == toolNameOrGUID or guid == toolNameOrGUID then
            return TradeManager.AddItemToTrade(tool)
        end
    end
    
    Log(string.format("Item not found: %s", toolNameOrGUID), "ERROR")
    return false
end

function PublicAPI.ManualConfirm()
    return TradeManager.ConfirmTrade()
end

