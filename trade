-- ============================================================================
-- TRADE REMOTE ACCESS
-- ============================================================================

local TradeRemote = nil

local function GetTradeRemote()
    if TradeRemote then return TradeRemote end
    
    TradeRemote = ReplicatedStorage
        :WaitForChild("Shared")
        :WaitForChild("Packages")
        :WaitForChild("Network")
        :WaitForChild("rev_trade_i")
    
    return TradeRemote
end

-- ============================================================================
-- INVENTORY SCANNING
-- ============================================================================

local InventoryScanner = {}

function InventoryScanner.GetItemGUID(tool)
    -- Get GUID from tool attributes
    -- Try common attribute names used by Roblox games
    local guid = tool:GetAttribute("GUID") or tool:GetAttribute("Id") or tool:GetAttribute("ItemId")
    
    if not guid then
        -- If no GUID attribute, use tool's Instance ID as fallback
        guid = tool:GetAttribute("UniqueId") or tostring(tool.Name)
    end
    
    return guid
end

function InventoryScanner.GetAllBrainrots()
    local allItems = {}
    
    -- Scan Backpack
    for _, tool in ipairs(Backpack:GetChildren()) do
        if tool:IsA("Tool") then
            table.insert(allItems, tool)
        end
    end
    
    -- Scan Character
    if Character then
        for _, tool in ipairs(Character:GetChildren()) do
            if tool:IsA("Tool") then
                table.insert(allItems, tool)
            end
        end
    end
    
    return allItems
end

function InventoryScanner.GetMatchingBrainrots()
    local matches = {}
    local items = InventoryScanner.GetAllBrainrots()
    
    for _, tool in ipairs(items) do
        local rarity = GetBrainrotRarity(tool.Name)
        
        if rarity and CONFIG.AllowedRarities[rarity] then
            local mutations = GetItemMutations(tool)
            
            table.insert(matches, {
                Name = tool.Name,
                Rarity = rarity,
                Mutations = mutations,
                Level = tool:GetAttribute("Level") or 1,
                Instance = tool,
            })
        end
    end
    
    -- Sort by rarity (descending priority)
    table.sort(matches, function(a, b)
        return GetRarityValue(a.Rarity) > GetRarityValue(b.Rarity)
    end)
    
    return matches
end

function InventoryScanner.PrintInventory()
    local matches = InventoryScanner.GetMatchingBrainrots()
    Log(string.format("Found %d matching items:", #matches), "INVENTORY")
    
    for i, item in ipairs(matches) do
        local mutationStr = #item.Mutations > 0 and table.concat(item.Mutations, ", ") or "None"
        Log(string.format(
            "  [%d] %s | Rarity: %s | Level: %d | Mutations: %s",
            i,
            item.Name,
            item.Rarity,
            item.Level,
            mutationStr
        ), "INVENTORY")
    end
    
    return matches
end

-- ============================================================================
-- TRADE MANAGEMENT
-- ============================================================================

local TradeManager = {}
TradeManager.isTradeActive = false
TradeManager.tradePartnerUserId = nil
TradeManager.itemsInTrade = {} -- Track which GUIDs we've added

function TradeManager.SendTradeRequest(userId)
    Log(string.format("Sending trade request to player %d", userId), "TRADE")
    
    -- Use actual game network: Network:InvokeServer("trade_r", userId)
    local success, message = Network:InvokeServer("trade_r", userId)
    
    if success then
        Log(string.format("Trade request sent successfully to %d", userId), "TRADE")
        TradeManager.isTradeActive = true
        TradeManager.tradePartnerUserId = userId
        TradeManager.itemsInTrade = {}
    else
        Log(string.format("Trade request failed: %s", message or "unknown error"), "ERROR")
    end
    
    return success
end

function TradeManager.AcceptTrade(userId)
    Log(string.format("Accepting trade from player %d", userId), "TRADE")
    
    -- Use actual game network: Network:FireServer("trade_start", userId)
    Network:FireServer("trade_start", userId)
    
    TradeManager.isTradeActive = true
    TradeManager.tradePartnerUserId = userId
    TradeManager.itemsInTrade = {}
end

function TradeManager.AddItemToTrade(tool)
    if not TradeManager.isTradeActive then
        Log("Cannot add item: no active trade", "WARN")
        return false
    end
    
    if not tool or not tool:IsA("Tool") then
        Log("Invalid tool provided", "ERROR")
        return false
    end
    
    local guid = GetItemGUID(tool)
    Log(string.format("Adding item to trade: %s (GUID: %s)", tool.Name, guid), "TRADE")
    
    -- FireServer("AddItem", itemGUID) on rev_trade_i remote
    local tradeRemote = GetTradeRemote()
    local args = {"AddItem", guid}
    
    local success, err = pcall(function()
        tradeRemote:FireServer(unpack(args))
    end)
    
    if not success then
        Log(string.format("Failed to add item: %s", err), "ERROR")
        return false
    end
    
    TradeManager.itemsInTrade[guid] = true
    return true
end

function TradeManager.RemoveItemFromTrade(tool)
    if not TradeManager.isTradeActive then
        Log("Cannot remove item: no active trade", "WARN")
        return false
    end
    
    local guid = GetItemGUID(tool)
    Log(string.format("Removing item from trade: %s (GUID: %s)", tool.Name, guid), "TRADE")
    
    -- FireServer("RemoveItem", itemGUID) on rev_trade_i remote
    local tradeRemote = GetTradeRemote()
    local args = {"RemoveItem", guid}
    
    local success, err = pcall(function()
        tradeRemote:FireServer(unpack(args))
    end)
    
    if not success then
        Log(string.format("Failed to remove item: %s", err), "ERROR")
        return false
    end
    
    TradeManager.itemsInTrade[guid] = nil
    return true
end

function TradeManager.ConfirmTrade()
    if not TradeManager.isTradeActive then
        Log("Cannot confirm: no active trade", "WARN")
        return false
    end
    
    Log("Confirming trade (both players must confirm)", "TRADE")
    
    -- FireServer("Confirm") on rev_trade_i remote
    local tradeRemote = GetTradeRemote()
    local args = {"Confirm"}
    
    local success, err = pcall(function()
        tradeRemote:FireServer(unpack(args))
    end)
    
    if not success then
        Log(string.format("Failed to confirm trade: %s", err), "ERROR")
        return false
    end
    
    return true
end

function TradeManager.EndTrade()
    Log("Ending trade session", "TRADE")
    TradeManager.isTradeActive = false
    TradeManager.tradePartnerUserId = nil
    TradeManager.itemsInTrade = {}
end

-- ============================================================================
-- AUTOMATION WORKFLOW
-- ============================================================================

local AutoTradeWorkflow = {}

function AutoTradeWorkflow.ExecuteFullTrade(userId)
    Log(string.format("=== STARTING FULL TRADE WORKFLOW FOR PLAYER %d ===", userId), "WORKFLOW")
    
    -- Step 1: Send the trade request
    local requestSuccess = TradeManager.SendTradeRequest(userId)
    if not requestSuccess then
        Log("Failed to send trade request", "ERROR")
        TradeManager.EndTrade()
        return false
    end
    
    wait(1) -- Give server time to set up trade
    
    -- Step 2: Scan inventory and get matching items
    local matchingItems = InventoryScanner.GetMatchingBrainrots()
    
    if #matchingItems == 0 then
        Log("No matching items found in inventory", "WARN")
        TradeManager.EndTrade()
        return false
    end
    
    Log(string.format("Found %d items to trade", #matchingItems), "WORKFLOW")
    
    -- Step 3: Add all matching items to trade
    for _, item in ipairs(matchingItems) do
        TradeManager.AddItemToTrade(item.Instance)
        wait(CONFIG.AddItemDelay)
    end
    
    -- Step 4: Wait a moment for UI to update
    wait(CONFIG.ConfirmDelay)
    
    -- Step 5: Confirm the trade
    TradeManager.ConfirmTrade()
    
    Log("=== TRADE WORKFLOW COMPLETE ===", "WORKFLOW")
    
    -- Note: Trade won't complete until the other player also confirms
    -- TODO: Listen for trade completion event if available
    
    return true
end

